<?xml version="1.0" encoding="UTF-8"?>
<sequence name="CheckBatchReadySeq" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <!-- Query batch_control to check if data_ready = 1 -->
    <dblookup>
        <connection>
            <pool>
                <dsName>insuranceDB</dsName>
                <property name="validationquery" value=""/>
            </pool>
        </connection>
        <statement>
            <sql><![CDATA[SELECT data_ready FROM batch_control WHERE job_id = ?]]></sql>
            <parameter value="J_001" type="VARCHAR"/>
            <result column="data_ready" name="data_ready"/>
        </statement>
    </dblookup>
    <variable name="dataReady" expression="${properties.synapse.data_ready}" type="STRING"/>
    <log category="INFO" logMessageID="false" logFullPayload="false">
        <message>CheckBatchReadySeq: data_ready=${vars.dataReady}</message>
    </log>
</sequence>