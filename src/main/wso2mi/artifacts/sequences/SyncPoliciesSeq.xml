<?xml version="1.0" encoding="UTF-8"?>
<sequence name="SyncPoliciesSeq" trace="disable" xmlns="http://ws.apache.org/ns/synapse">
    <!-- Step 1: Lock - set data_ready = 0 -->
    <log category="INFO">
        <message>SyncPoliciesSeq: Locking gatekeeper (data_ready = 0)</message>
    </log>
    <dbreport>
        <connection>
            <pool>
                <driver>com.mysql.cj.jdbc.Driver</driver>
                <url>jdbc:mysql://localhost:3306/insurance</url>
                <user>root</user>
                <password>12345</password>
                <property name="validationquery" value=""/>
            </pool>
        </connection>
        <statement>
            <sql><![CDATA[UPDATE batch_control SET data_ready = 0 WHERE job_id = 'J_001']]></sql>
        </statement>
    </dbreport>
    <!-- Step 2: Truncate valid_policies mirror table -->
    <log category="INFO">
        <message>SyncPoliciesSeq: Truncating valid_policies table</message>
    </log>
    <dbreport>
        <connection>
            <pool>
                <driver>com.mysql.cj.jdbc.Driver</driver>
                <url>jdbc:mysql://localhost:3306/insurance</url>
                <user>root</user>
                <password>12345</password>
                <property name="validationquery" value=""/>
            </pool>
        </connection>
        <statement>
            <sql><![CDATA[TRUNCATE TABLE valid_policies]]></sql>
        </statement>
    </dbreport>
    <!-- Step 3: Insert active policies from policies table into valid_policies -->
    <log category="INFO">
        <message>SyncPoliciesSeq: Inserting active policies into valid_policies</message>
    </log>
    <dbreport>
        <connection>
            <pool>
                <driver>com.mysql.cj.jdbc.Driver</driver>
                <url>jdbc:mysql://localhost:3306/insurance</url>
                <user>root</user>
                <password>12345</password>
                <property name="validationquery" value=""/>
            </pool>
        </connection>
        <statement>
            <sql><![CDATA[INSERT INTO valid_policies (policy_id) SELECT policy_id FROM policies WHERE status = 'Active';]]></sql>
        </statement>
    </dbreport>
    <!-- Step 4: Store a trigger message for the 5-minute delayed unlock -->
    <log category="INFO">
        <message>SyncPoliciesSeq: Storing unlock trigger message for 5-minute delay</message>
    </log>
    <variable name="syncTimestamp" expression="${string(now())}" type="STRING"/>
    <payloadFactory media-type="json">
        <format>{"trigger": "unlock", "timestamp": "${vars.syncTimestamp}"}</format>
    </payloadFactory>
    <store messageStore="UnlockTriggerStore"/>
    <log category="INFO">
        <message>SyncPoliciesSeq: Sync complete. Unlock scheduled in 5 minutes.</message>
    </log>
</sequence>